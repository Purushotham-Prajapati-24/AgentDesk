{
  "name": "@agentdesk/react",
  "version": "0.1.0",
  "description": "AgentDesk AI chat widget — React & Next.js SDK",
  "keywords": ["agentdesk", "chat", "widget", "react", "nextjs", "support", "bot"],
  "license": "MIT",
  "author": "AgentDesk",
  "homepage": "https://github.com/anomalyco/AI_Support_Agent#readme",
  "bugs": {
    "url": "https://github.com/anomalyco/AI_Support_Agent/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anomalyco/AI_Support_Agent.git",
    "directory": "packages/react"
  },
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./nextjs": {
      "types": "./dist/nextjs.d.ts",
      "import": "./dist/nextjs.js",
      "require": "./dist/nextjs.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "next": ">=13.0.0"
  },
  "peerDependenciesMeta": {
    "react-dom": { "optional": true },
    "next": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^19",
    "react": "^19",
    "react-dom": "^19",
    "tsup": "^8",
    "typescript": "^5"
  }
}
