{
  "name": "@agentdeskbot/vue",
  "version": "0.1.0",
  "description": "AgentDesk AI chat widget — Vue 3 SDK",
  "keywords": [
    "agentdesk",
    "chat",
    "widget",
    "vue",
    "vue3",
    "nuxt",
    "support",
    "bot"
  ],
  "license": "MIT",
  "author": "AgentDesk",
  "homepage": "https://github.com/Purushotham-Prajapati-24/AgentDesk#readme",
  "bugs": {
    "url": "https://github.com/Purushotham-Prajapati-24/AgentDesk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Purushotham-Prajapati-24/AgentDesk.git",
    "directory": "packages/vue"
  },
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run"
  },
  "peerDependencies": {
    "vue": ">=3.0.0"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^5",
    "vue": "^3"
  },
  "dependencies": {
    "@agentdeskbot/core": "^0.1.0"
  }
}
