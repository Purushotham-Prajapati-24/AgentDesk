# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js build output
/.next/
/out/
/build

# Workspace package build output (tsup, rollup, esbuild)
packages/*/dist/

# TypeScript build cache
*.tsbuildinfo
next-env.d.ts

# Environment files — never commit secrets
.env*

# One-off debug & maintenance scripts (root-level .mjs files)
check-tenants.mjs
create-collection.mjs
fix-schema.mjs
get-document-files-attributes.mjs
get-ledger-attributes.mjs
list-collections.mjs
reset-tenants.mjs
setup-missing-collections.mjs
setup-schema.mjs
update-all-collections.mjs
update-collection.mjs
test-ensure.mjs
test-get.mjs
test-guest.mjs
test-pdf.mjs
test-verify.mjs

# Agent tooling & AI assistant config (not part of the app)
/.agent
/processStatus
CLAUDE.md
# Vercel deployment config
.vercel

# OS / IDE artefacts
.DS_Store
Thumbs.db
*.pem
*.sublime-workspace
*.sublime-project
.idea/
.vscode/settings.json
.vscode/*.code-workspace

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Test coverage
/coverage
.agent
node_modules
Docs folder (design artefacts, not shipped code)
/docs
index.html
verification-screenshots
