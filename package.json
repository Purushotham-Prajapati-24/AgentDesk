{
  "name": "agentdesk",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev --webpack",
    "dev:ws": "npm --prefix websocket-server start",
    "build": "npm run build:widget && npm run build:sdk && next build",
    "build:sdk": "npm run build -w @agentdeskbot/core && npm run build -w @agentdeskbot/react -w @agentdeskbot/vue",
    "build:widget": "node scripts/build-widget.mjs",
    "qdrant:hybrid": "node --env-file=.env.local scripts/create-qdrant-hybrid.mjs",
    "setup:ingestion": "node --env-file=.env.local scripts/setup-ingestion-schema.mjs",
    "start": "next start",
    "test": "node --experimental-strip-types --test test/*.test.mjs",
    "test:sdk": "vitest run",
    "typecheck": "npm run typecheck -w @agentdeskbot/core && npm run typecheck -w @agentdeskbot/react -w @agentdeskbot/vue",
    "lint": "eslint"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@qdrant/js-client-rest": "^1.18.0",
    "@splinetool/react-spline": "^4.1.0",
    "appwrite": "^25.2.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.16.0",
    "mammoth": "^1.12.0",
    "next": "16.2.6",
    "node-appwrite": "^25.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io-client": "^4.8.3",
    "turndown": "^7.2.4",
    "unpdf": "^1.6.2",
    "word-extractor": "^1.0.4",
    "zod": "^4.4.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/turndown": "^5.0.6",
    "@vue/test-utils": "^2.4.11",
    "agentation": "^3.0.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^24.1.0",
    "playwright": "^1.60.0",
    "tailwindcss": "^4",
    "tsup": "^8.5.1",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
